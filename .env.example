# Copy this file to `.env.local` and fill in values. Next.js loads `.env.local` automatically
# from the project root (restart `npm run dev` after edits).
#
# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase — Project Settings → API
# Project URL must be https://xxxx.supabase.co (not a key)
NEXT_PUBLIC_SUPABASE_URL=
# Server-only: use the Secret key (sb_secret_...) OR legacy "service_role" JWT
SUPABASE_SERVICE_ROLE_KEY=

# ElevenLabs Conversational AI — agent ID from ElevenLabs dashboard (public)
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# Anthropic (Claude) — CV generation & PDF parsing — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Default: claude-3-5-haiku-20241022
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# CV / cover PDFs: compile generated LaTeX so output matches templates/cv-main.tex.
# Install one of: brew install tectonic   OR   MacTeX / TeX Live (pdflatex on PATH).
# Without this, PDFs fall back to plain Helvetica (does not match the LaTeX design).
# DISABLE_LATEX_PDF=1
# Prefer engine if both exist: tectonic | pdflatex
# LATEX_PDF_ENGINE=tectonic
