# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase — Project Settings → API
# Project URL must be https://xxxx.supabase.co (not a key)
NEXT_PUBLIC_SUPABASE_URL=
# Server-only: use the Secret key (sb_secret_...) OR legacy "service_role" JWT
SUPABASE_SERVICE_ROLE_KEY=

# Google AI (Gemini) — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional override (default: gemini-1.5-flash)
# GOOGLE_AI_MODEL=gemini-2.0-flash
