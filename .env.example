# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase — Project Settings → API
# Project URL must be https://xxxx.supabase.co (not a key)
NEXT_PUBLIC_SUPABASE_URL=
# Server-only: use the Secret key (sb_secret_...) OR legacy "service_role" JWT
SUPABASE_SERVICE_ROLE_KEY=

# Google AI (Gemini) — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Default in code is gemini-2.5-flash (gemini-2.0-flash is retired for new users).
# GOOGLE_AI_MODEL=gemini-2.5-flash

# CV / cover PDFs: compile generated LaTeX so output matches templates/cv-main.tex.
# Install one of: brew install tectonic   OR   MacTeX / TeX Live (pdflatex on PATH).
# Without this, PDFs fall back to plain Helvetica (does not match the LaTeX design).
# DISABLE_LATEX_PDF=1
# Prefer engine if both exist: tectonic | pdflatex
# LATEX_PDF_ENGINE=tectonic
